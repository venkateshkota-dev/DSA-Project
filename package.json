{
  "name": "cinebook-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "DSA"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev": "concurrently -n \"client,server\" -c \"bgBlue,bgGreen\" \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "test": "npm test --workspace=dsa"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
